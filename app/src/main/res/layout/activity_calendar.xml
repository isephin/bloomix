<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F5EC"
    android:padding="16dp"
    tools:context=".CalendarActivity">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:id="@+id/topNavBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp">

        <ImageView
            android:id="@+id/btnHistory"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/tulip"
            android:contentDescription="@string/past_entries"/>

        <ImageView
            android:id="@+id/iconBarChart"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/bar_chart"
            android:layout_marginStart="16dp"
            android:contentDescription="@string/statistics"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageView
            android:id="@+id/iconSettings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/settings"
            android:contentDescription="@string/settings"/>
    </LinearLayout>

    <!-- Guidelines for consistent spacing -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.22" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85" />

    <!-- Month Navigation -->
    <ImageView
        android:id="@+id/btnPrev"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/arrow_calendar"
        android:contentDescription="@string/previous_month"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideLineTop"
        app:layout_constraintBottom_toTopOf="@id/dayHeaderLayout"
        app:layout_constraintVertical_bias="0.5" />

    <TextView
        android:id="@+id/tvMonthTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="November"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/dark_grey"
        android:fontFamily="@font/gamja_flower"
        app:layout_constraintStart_toEndOf="@id/btnPrev"
        app:layout_constraintEnd_toStartOf="@id/btnNext"
        app:layout_constraintTop_toTopOf="@id/guideLineTop"
        app:layout_constraintBottom_toTopOf="@id/dayHeaderLayout"
        app:layout_constraintVertical_bias="0.5"
        android:gravity="center"/>

    <ImageView
        android:id="@+id/btnNext"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/arrow_calendar"
        android:rotation="180"
        android:contentDescription="@string/next_month"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideLineTop"
        app:layout_constraintBottom_toTopOf="@id/dayHeaderLayout"
        app:layout_constraintVertical_bias="0.5" />

    <!-- Day Headers (Sun, Mon...) -->
    <LinearLayout
        android:id="@+id/dayHeaderLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="7"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvMonthTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:text="Sun" style="@style/DayHeaderLarge" />
        <TextView android:text="Mon" style="@style/DayHeaderLarge" />
        <TextView android:text="Tue" style="@style/DayHeaderLarge" />
        <TextView android:text="Wed" style="@style/DayHeaderLarge" />
        <TextView android:text="Thu" style="@style/DayHeaderLarge" />
        <TextView android:text="Fri" style="@style/DayHeaderLarge" />
        <TextView android:text="Sat" style="@style/DayHeaderLarge" />

    </LinearLayout>

    <!-- Calendar Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewCalendar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/dayHeaderLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_day"/>

</androidx.constraintlayout.widget.ConstraintLayout>