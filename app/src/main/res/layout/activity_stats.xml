<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/statsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F5EC"
    android:padding="16dp">

    <!-- Top Navigation -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rectangle_container"
            android:src="@drawable/arrow_back"
            android:padding="12dp"
            app:tint="@color/ash_grey" />

        <!-- Navigation Group (Centered) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnPrevMonth"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@null"
                android:src="@drawable/arrow_back"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="#333333"/>

            <TextView
                android:id="@+id/tvStatsDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/gamja_flower"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:text="2025.09"
                android:textColor="@color/dark_grey"
                android:textSize="36sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"/>

            <ImageButton
                android:id="@+id/btnNextMonth"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@null"
                android:src="@drawable/arrow_back"
                android:rotation="180"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:tint="#333333"/>
        </LinearLayout>

        <!-- Spacer to balance the Back button -->
        <View android:layout_width="48dp" android:layout_height="48dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/statsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:id="@+id/containerStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- 1. GARDEN CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGarden"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gamja_flower"
                            android:text="My Garden"
                            android:textColor="#333333"
                            android:textSize="34sp" />

                        <TextView
                            android:id="@+id/tvFlowerCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gamja_flower"
                            android:text="0"
                            android:textColor="#888888"
                            android:textSize="24sp"
                            android:layout_marginEnd="8dp"/>

                        <!-- Arrow Icon for Garden -->
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/arrow_back"
                            android:rotation="180"
                            app:tint="#C7785F" />
                    </LinearLayout>

                    <!-- Horizontal List of Flower Cards -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/gardenContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. EMOTIONS LIST CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/gamja_flower"
                        android:text="Emotion of the Month"
                        android:textColor="#333333"
                        android:textSize="34sp"
                        android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:id="@+id/emotionsListContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/btnShowMore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View More v"
                        android:fontFamily="@font/gamja_flower"
                        android:gravity="center"
                        android:textColor="#888888"
                        android:textSize="22sp"
                        android:paddingTop="16dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. DAILY EMOTIONS (Chart) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gamja_flower"
                            android:text="Daily Emotions"
                            android:textColor="#333333"
                            android:textSize="34sp" />
                        <TextView
                            android:id="@+id/tvAvgEmotions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gamja_flower"
                            android:text="avg. 0"
                            android:textColor="#888888"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:fillViewport="true">
                        <LinearLayout
                            android:id="@+id/dailyChartContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="bottom" />
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 4. POSITIVITY INDEX -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gamja_flower"
                            android:text="Positivity Index"
                            android:textColor="#333333"
                            android:textSize="34sp" />
                        <TextView
                            android:id="@+id/tvAvgPositive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/gamja_flower"
                            android:text="avg. 0%"
                            android:textColor="#888888"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:fillViewport="true">
                        <LinearLayout
                            android:id="@+id/positiveIndexContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="bottom" />
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>