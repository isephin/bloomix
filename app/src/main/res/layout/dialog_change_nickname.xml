<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/popup_bg" >

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Change Nickname"
        android:textSize="25sp"
        android:fontFamily="@font/gamja_flower"
        android:textColor="@color/dark_grey"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etNewNickname"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter new nickname"
        android:inputType="textPersonName|textCapWords"
        android:textSize="20sp"
        android:fontFamily="@font/gamja_flower"
        android:padding="12dp"
        android:background="@drawable/rectangle_container"
        android:layout_marginBottom="24dp"
        android:autofillHints="nickname" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:textSize="18sp"
            android:fontFamily="@font/gamja_flower"
            android:textColor="@color/white"
            android:background="@drawable/rectangle_container"
            android:backgroundTint="@color/ash_grey"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save"
            android:textSize="18sp"
            android:fontFamily="@font/gamja_flower"
            android:textColor="@color/white"
            android:background="@drawable/rectangle_container"
            android:backgroundTint="@color/dark_grey"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>