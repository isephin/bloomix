<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="4dp">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingEnd="4dp"
        android:clipChildren="false">

        <ImageView
            android:id="@+id/chipImage"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/happy"
            android:contentDescription="Emotion Icon"
            android:padding="4dp"
            android:background="@drawable/rectangle_container" />

        <TextView
            android:id="@+id/chipCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_red_badge"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="center"
            android:minWidth="16dp"
            android:minHeight="16dp"
            android:text="1"
            android:layout_alignTop="@id/chipImage"
            android:layout_alignEnd="@id/chipImage"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-4dp" />
    </RelativeLayout>

    <TextView
        android:id="@+id/chipLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Emotion"
        android:textSize="12sp"
        android:textColor="@color/dark_grey"
        android:fontFamily="@font/gamja_flower"
        android:layout_marginTop="2dp" />

</LinearLayout>