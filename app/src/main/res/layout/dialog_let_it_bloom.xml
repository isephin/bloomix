<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_bg"
    android:padding="24dp">

    <!-- Central Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Main Confirmation Text (Styled as Title) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Are you ready to let your flower bloom?"
            android:textSize="24sp"
            android:textColor="@color/peach"
            android:fontFamily="@font/gamja_flower"
            android:textAlignment="center"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Warning Text (Styled as Subtitle) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You cannot change the emotions and journal after you continue."
            android:textSize="14sp"
            android:textColor="@color/ash_grey"
            android:fontFamily="@font/gamja_flower"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <!-- Buttons Container (Horizontal) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- "Go Back" Button -->
            <Button
                android:id="@+id/btnClosePopup"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Go Back"
                android:background="@drawable/rectangle_container"
                android:textColor="@color/dark_grey"
                android:fontFamily="@font/gamja_flower"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp" />

            <!-- "Let It Bloom" Button -->
            <Button
                android:id="@+id/btnLetItBloom"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Let It Bloom!"
                android:background="@drawable/login_button"
                android:textColor="@color/off_white"
                android:fontFamily="@font/gamja_flower"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>