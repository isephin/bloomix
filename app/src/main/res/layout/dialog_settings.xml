<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/popup_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/arrow_back"
            android:background="@drawable/rectangle_container"
            android:contentDescription="@string/btn_desc_back"
            app:tint="@color/ash_grey"
            android:padding="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="25dp">

        <TextView
            android:id="@+id/tvNicknameLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nickname"
            android:textSize="25sp"
            android:fontFamily="@font/gamja_flower"
            android:textColor="@color/dark_grey"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnChangeNickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change"
            android:textSize="25sp"
            android:fontFamily="@font/gamja_flower"
            android:textColor="@color/ash_grey"
            android:textStyle="bold"
            app:drawableEndCompat="@drawable/arrow_next"
            android:drawablePadding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log out"
        android:textSize="20sp"
        android:fontFamily="@font/gamja_flower"
        android:textColor="@color/white"
        android:background="@drawable/rectangle_container"
        android:paddingVertical="12dp"
        android:layout_marginTop="32dp"
        tools:backgroundTint="@color/dark_grey" />

</LinearLayout>