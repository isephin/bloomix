<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white"
    android:padding="16dp">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rectangle_container"
            android:src="@drawable/ic_close"
            android:padding="12dp"
            app:tint="@color/ash_grey" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/gamja_flower"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:text="2025.09"
            android:textColor="@color/dark_grey"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rectangle_container"
            android:src="@drawable/ic_menu_dots"
            android:padding="12dp"
            app:tint="@color/ash_grey" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- CARD 1: Flower Language -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#EAEAEA"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- White Box inside Grey Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardBackgroundColor="@color/off_white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/gamja_flower"
                                    android:text="Your flower of\nthe day is a"
                                    android:textColor="@color/ash_grey"
                                    android:paddingBottom="8dp"
                                    android:textSize="18sp" />

                                <TextView
                                    android:id="@+id/flowerName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/gamja_flower"
                                    android:text="Red Rose"
                                    android:textColor="@color/dark_grey"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/flowerImage"
                                android:layout_width="85dp"
                                android:layout_height="85dp"
                                android:src="@drawable/rose" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Keywords -->
                    <TextView
                        android:id="@+id/flowerKeywords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/gamja_flower"
                        android:gravity="center"
                        android:text="Passion + Love + Devotion"
                        android:textColor="@color/dark_grey"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- Long Description -->
                    <TextView
                        android:id="@+id/flowerLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/gamja_flower"
                        android:lineSpacingMultiplier="1.2"
                        android:text="Red roses are the universal symbol of love..."
                        android:textColor="@color/ash_grey"
                        android:textSize="16sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- CARD 2: Sentiment Analysis -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvSentiment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/gamja_flower"
                        android:gravity="center"
                        android:text="Sentiment: Positive"
                        android:textColor="@color/dark_grey"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:fontFamily="@font/gamja_flower"
                        android:text="Overall mood: Complex Emotional Landscape"
                        android:textColor="@color/ash_grey"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvReflectionPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/gamja_flower"
                        android:lineSpacingMultiplier="1.2"
                        android:text="Loving is a nice feeling what are other things that make you feel loved?"
                        android:textColor="#555555"
                        android:textSize="18sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 3: Micro Action -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/gamja_flower"
                        android:gravity="center"
                        android:text="Micro-action for you"
                        android:textColor="@color/ash_grey"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/microAction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/gamja_flower"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.2"
                        android:text="Celebrate this moment! Share your love..."
                        android:textColor="@color/dark_grey"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 4: Emotion Stats (Percentages) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/emotionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="@font/gamja_flower"
                        android:text="Emotions"
                        android:textColor="@color/ash_grey"
                        android:textSize="16sp" />

                    <!-- Emotion bars will be added dynamically here -->

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 5: Journal Entry -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/gamja_flower"
                        android:text="Journal"
                        android:textColor="@color/ash_grey"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/journalEntry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/gamja_flower"
                        android:lineSpacingMultiplier="1.2"
                        android:text="Today a stranger gave me flowers..."
                        android:textColor="@color/dark_grey"
                        android:textSize="18sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>