<?xml version="1.0" encoding="utf-8"?>
<!--
  Defines a simple solid white background with rounded corners.
  This resource is required by activity_flower_result.xml to resolve the build error.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Solid color for the background -->
    <solid android:color="@android:color/white" />

    <!-- Define the radius for the rounded corners -->
    <corners android:radius="16dp" />

    <!-- Optional: Add a light border/stroke for better definition -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" />
</shape>